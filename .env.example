PORT=3000
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=GPO
JWT_SECRET=gpo_secret_key_change_in_production
JWT_EXPIRES_IN=24h

# Email (SMTP) — laisser vide en développement : les emails s'affichent alors dans la console
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SoliDev Platform" <noreply@solidev.africa>
ADMIN_EMAIL=admin@gpo.org

# URL publique de l'application (utilisée dans les liens des emails)
APP_URL=http://localhost:3000

# CORS — origines autorisées, séparées par des virgules
ALLOWED_ORIGINS=http://localhost:3000

# IA (optionnel — recherche d'opportunités via Claude)
ANTHROPIC_API_KEY=

NODE_ENV=development
