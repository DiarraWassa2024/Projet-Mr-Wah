PORT=3000
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=GPO
JWT_SECRET=gpo_secret_key_change_in_production
JWT_EXPIRES_IN=24h

# Email — priorité : Resend (si RESEND_API_KEY défini) > SMTP > console (mode mock, dev)
# Resend (recommandé — bien plus fiable qu'un relais Gmail personnel, notamment vers iCloud/Outlook)
RESEND_API_KEY=
RESEND_FROM="SoliDev Platform" <onboarding@resend.dev>

# SMTP — utilisé seulement si RESEND_API_KEY n'est pas défini
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SoliDev Platform" <noreply@solidev.africa>
ADMIN_EMAIL=admin@gpo.org

# URL publique de l'application (utilisée dans les liens des emails)
APP_URL=http://localhost:3000

# CORS — origines autorisées, séparées par des virgules
ALLOWED_ORIGINS=http://localhost:3000

# IA (optionnel — recherche d'opportunités via Claude)
ANTHROPIC_API_KEY=

NODE_ENV=development
